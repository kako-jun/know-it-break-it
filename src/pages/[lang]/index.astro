---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'ja' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as 'ja' | 'en';
---

<BaseLayout
  title="Know It. Break It."
  description="あたまのネジとはずしかた — Learn the rules. Then break them."
  lang={lang}
>
  <main>
    <section class="hero">
      <h1>あたまのネジとはずしかた</h1>
      <p class="tagline">Know It. Break It.</p>
      <p class="description">
        プロが見ているポイントがある。それは言語化できる。<br />
        型を知って、武器にしろ。
      </p>
    </section>

    <section class="domains">
      <h2>ドメイン</h2>
      <ul>
        <li>美術（構図・象徴）</li>
        <li>音楽（コード・転調）</li>
        <li>漫才（転回・普遍性）</li>
        <li>漫画（編集者の評価軸）</li>
        <li>映画（ストーリー構造）</li>
      </ul>
    </section>

    <section class="cta">
      <a href={`/${lang}/articles/`}>記事一覧を見る</a>
    </section>
  </main>
</BaseLayout>
