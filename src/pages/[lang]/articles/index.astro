---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  domainLabels,
  difficultyLabels,
  difficultyClasses,
  getArticleHref,
  formatDate,
  formatDateIso,
  uiLabels,
  getStaticPathsForLang,
  type Locale,
} from '../../../lib/i18n';

export function getStaticPaths() {
  return getStaticPathsForLang();
}

const lang = Astro.params.lang as Locale;
const articles = await getCollection('articles', ({ data }) => data.lang === lang);
const labels = uiLabels[lang];
---

<BaseLayout
  title={`${labels.articleListTitle} | Know It. Break It.`}
  description={labels.articleListDescription}
  lang={lang}
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">{labels.articleListTitle}</h1>

    <div class="grid gap-6 md:grid-cols-2">
      {
        articles.map((article) => (
          <a
            href={getArticleHref(article)}
            class="block p-6 bg-white border border-gray-200 rounded-lg hover:shadow-md transition-shadow"
          >
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="inline-block px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                {domainLabels[lang][article.data.domain]}
              </span>
              <span
                class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${difficultyClasses[article.data.difficulty]}`}
              >
                {difficultyLabels[lang][article.data.difficulty]}
              </span>
            </div>

            <h2 class="text-xl font-semibold text-gray-900 mb-2">{article.data.title}</h2>

            <p class="text-gray-600 text-sm line-clamp-2 mb-3">{article.data.description}</p>

            <div class="flex flex-wrap gap-1.5 mb-3">
              {article.data.tags.map((tag) => (
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-blue-50 text-blue-700">
                  {tag}
                </span>
              ))}
            </div>

            <time class="text-xs text-gray-400" datetime={formatDateIso(article.data.publishedAt)}>
              {formatDate(article.data.publishedAt, lang)}
            </time>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>
