---
import LanguageSwitch from '../components/LanguageSwitch.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Know It. Break It.', lang = 'ja' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="max-w-4xl mx-auto px-4 py-4 flex justify-end">
      <LanguageSwitch currentLang={lang as 'ja' | 'en'} currentPath={currentPath} />
    </header>
    <slot />
  </body>
</html>
