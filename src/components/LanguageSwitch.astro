---
import type { Locale } from '../lib/i18n';
import { getAlternateLocale, getLocalizedPath } from '../lib/i18n';

interface Props {
  currentLang: Locale;
  currentPath: string;
  alternateHref?: string;
}

const { currentLang, currentPath, alternateHref } = Astro.props;
const targetLang = getAlternateLocale(currentLang);
const targetPath = alternateHref ?? getLocalizedPath(currentPath, currentLang, targetLang);

const labels: Record<Locale, string> = {
  ja: '日本語',
  en: 'English',
};
---

<div class="flex items-center gap-2 text-sm">
  <span class="text-gray-500">{labels[currentLang]}</span>
  <span class="text-gray-300">|</span>
  <a href={targetPath} class="text-blue-600 hover:text-blue-800 font-medium transition-colors">
    {labels[targetLang]}
  </a>
</div>
